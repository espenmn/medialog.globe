<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html xmlns="http://www.w3.org/1999/xhtml"
  xmlns:i18n="http://xml.zope.org/namespaces/i18n"
  xmlns:tal="http://xml.zope.org/namespaces/tal" lang="en" xml:lang="en" i18n:domain="plone">
  <body>
    <tal:defines define="
                   batch context;
                   original_context nocall:options/original_context|context;
                   toLocalizedTime nocall:original_context/@@plone/toLocalizedTime;
                   pas_member nocall:original_context/@@pas_member;
                   show_about python:True;
                   registry original_context/portal_registry;
                   view_types python: registry.get('plone.types_use_view_action_in_listings', []);
                 ">
      <tal:listing condition="batch">

        <tal:entry repeat="item batch">
          <article class="entry" tal:define="obj item/getObject;
                item_url item/getURL;
                item_id item/getId;
                item_title item/Title;
                item_title python:item_title or item_id;
                item_description item/Description;
                item_type item/PortalType;
                item_modified item/ModificationDate;
                item_created item/CreationDate;
                item_wf_state item/review_state;
                showicons view/show_icons|None;
                item_wf_state_class python:'state-' + (item_wf_state or '');
                item_creator item/Creator;
                item_link item_url;
                item_has_image python:item.getIcon;
                item_type_class python: '' ;
                ">
            <!-- <header metal:define-macro="listitem" tal:attributes="class python:'vevent' if item_type=='Event' else None"> -->
              <!--div class="globe-div"-->

              <a href="#" tal:condition="item_has_image" tal:attributes="href item_url">
                <img tal:condition="item_has_image" tal:attributes="src string:${item/getURL}/@@images/image/preview" alt=""/>
              </a>
              <div class="media-body padding-0-20">
                <a href="${item_url}">
                  <h2 class="media-heading black margin-10-0">${item_title}</h2>
                </a>
                <!-- p class="work-title"><i>${item/Description}</i></p-->
                <a href="${item_url}">
                  <button class="plone-background-2 white margin-10-0">Lees verder</button>
                </a>
              </div>

            </article>


          </tal:entry>



          <div metal:use-macro="original_context/batch_macros/macros/navigation"></div>
        </tal:listing>
        <p class="text-bg-secondary" tal:condition="not:batch" i18n:translate="">
        There are currently no items in this folder.
        </p>
      </tal:defines>


      <style>

  div.entries { display: flex; flex-wrap: wrap;
     max-width: 1200px;
  }

  .margin-10-0 {margin: 10}

  #content-core {
    margin-left: -15px;
    margin-right: -15px;
  }

  text-align-center {
  text-align: center;
  }
  .padding-5-10 {
    padding: 5px 10px;
    text-align: center;
  }

  li.filterItem  a span {
    color: #041c2c;
    font-weight: bold !important;
  }

  li.filterItem.selected  a span   {
    color: #da291b;
  }

  li.filterItem a::before {
    content: "/" !important;
    color: #041c2c;
  }

   
  .seksjons_block {
    padding: 0 80px;
    text-align: center;
  }

  .seksjons_block .container {
    margin-top: 50px;
    margin-bottom: 50px;
  }

  .seksjons_block h1 {
    font-size: 52px;
  }

  .seksjons_block p {
    font-size: 1.9em;
    max-width: 800px;
    margin: auto;
  }

  div.portletContent.filterContent,
  .portletWrapper,
  .portlet {
    border-color: none !important;
    box-shadow: none !important;
    background: none !important;
    border-top: 0 none  !important;
  }



  #above-portlets-wrapper div.container.flex,

          #aboveall-portlets-wrapper div.container.flex {
    max-width: 1200px;
  }

  article.entry{
    float: left;
    min-height: 400px;
    text-align: center;
    background: whitesmoke;
    margin: 10px;
  }

  article.entrybutton {
  border-color: white;
  }

  .template-globee-view  .portletWrapper {
    width: 100%;
    margin: 0;
  }

  .template-globee-view  header.portletHeader {
    margin: 1em 0 0 0;
    padding: 0 14px;
    font-size: 100%;
    display: none;
  }

  li.filterItem.filter-skade. {
    display: flex;
  }

  .collectionFilter.pat-collectionfilter div.portletContent.filterContent ul {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
  }



  h1.documentFirstHeading {
    text-align: center;
    display: none;
  }

  .globe-div {
    margin: 15px !important;

    float: left;
  }

  #content-core div.globe-div.white-background a img {
    height: 25%;
    width:  100%;
    object-position: 0 0;
    object-fit: cover;
  }

  .globe-div  a {
    text-decoration: none !important;
    border-bottom: 0 none !important;
  }

  body.template-globe-view .outer-wrapper {
    xbackground: whitesmoke;
    xpadding-top: 175px;
  }

  body.template-globee-view h1.documentFirstHeading {
    border-bottom: 0;
    text-align: center;
  }

  body.template-globee-view div.media-body.padding-20 p a {
    border-style: none;
  }

  body.template-globee-viewv h2.media-heading {
    margin-top: 0;
  }

  body.template-globee-view div.media-body hr {
    border-color: whitesmoke;
    margin-top: 10px;
  }

  p.work-title {
    margin-bottom: 30px;
  }

  article.entry{
    width: calc(25% - 30px);
    min-width: 240px;
    max-width: 400px;
  }

  article.entry p.eposten a {
    font-size: 85%;
  }

  @media (max-width:1000px) {

  article.entry{
    width: 45%;
    min-width: 250px;
    max-width: 300px;
  }

  }

  @media (max-width:550px) {

  article.entry{
    width: auto;
    min-width: 250px;
    max-width: 100%;
  }

}


.clear-both {clear: both;}

      </style>

    </body>
  </html>
